// 使用 Node.js 启动静态服务器，并在浏览器中打开页面
{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Run with Node.js",
            "program": "${workspaceFolder}/server.js",
            "cwd": "${workspaceFolder}",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "serverReadyAction": {
                "pattern": "Server running at (http://127.0.0.1:3000)",
                "uriFormat": "%s",
                "action": "openExternally"
            }
        }
    ]
}